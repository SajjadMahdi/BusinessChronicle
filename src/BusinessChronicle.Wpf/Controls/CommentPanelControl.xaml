<UserControl x:Class="BusinessChronicle.Wpf.Controls.CommentPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ListBox ItemsSource="{Binding Comments, RelativeSource={RelativeSource AncestorType=UserControl}}">
        <ListBox.ItemTemplate>
            <DataTemplate>
                <StackPanel>
                    <TextBlock FontWeight="Bold" Text="{Binding Author.DisplayName}" />
                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                </StackPanel>
            </DataTemplate>
        </ListBox.ItemTemplate>
    </ListBox>
</UserControl>
