<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] — Chronicle ERP</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,600;9..40,700&family=IBM+Plex+Serif:wght@600&display=swap" rel="stylesheet" />
</head>
<body>
    <header class="site-header">
        <a class="brand" asp-controller="Home" asp-action="Index">
            <span class="brand__mark">◆</span> Chronicle ERP
        </a>
        <nav>
            <a asp-controller="Home" asp-action="Index">Overview</a>
            <a asp-controller="Properties" asp-action="Index">Properties</a>
        </nav>
    </header>
    <main class="site-main">
        @RenderBody()
    </main>
    <footer class="site-footer">
        <p>BusinessChronicle MVC sample — audit-grade lease tracking for commercial real estate portfolios.</p>
    </footer>
</body>
</html>
